# Cadmus needs a model API key for any LLM-based processor.
#
# Default model is Gemini. Get a free key at:
#   https://aistudio.google.com/apikey
#
# Provider routing is automatic from the model name:
#   gemini-*  -> Google  (uses GOOGLE_API_KEY)
#   claude-*  -> Anthropic (uses ANTHROPIC_API_KEY)

GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=

# Override defaults if you want:
# CADMUS_PORT=4000
# CADMUS_STUDIO_PORT=3001
