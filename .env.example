# Cadmus needs an API key for at least one LLM provider.
# Provider routing is automatic from the model name in your agent's config:
#   gemini-*  -> uses GOOGLE_API_KEY
#   claude-*  -> uses ANTHROPIC_API_KEY
#
# Get an API key:
#   Google Gemini      https://aistudio.google.com/apikey
#   Anthropic Claude   https://console.anthropic.com/settings/keys

# GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=

# Optional overrides:
# CADMUS_PORT=4000
# CADMUS_STUDIO_PORT=3001
